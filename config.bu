variant: fcos
version: 1.5.0
boot_device:
  luks:
    tpm2: true
passwd:
  users:
    - name: aburela
      ssh_authorized_keys:
        - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMcGI9OoXJ2nVRoIiYqqJIwxo3NgVVBvCyVfs1tjrbzb uno@arturoburela.com
      groups:
        - wheel
        - sudo
storage:
  files:
    - path: /etc/sudoers.d/aburela
      mode: 0440
      contents:
        inline: "aburela ALL=(ALL) NOPASSWD: ALL"
