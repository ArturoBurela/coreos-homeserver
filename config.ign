{
  "ignition": {
    "version": "3.4.0"
  },
  "passwd": {
    "users": [
      {
        "groups": [
          "wheel",
          "sudo"
        ],
        "name": "aburela",
        "sshAuthorizedKeys": [
          "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMcGI9OoXJ2nVRoIiYqqJIwxo3NgVVBvCyVfs1tjrbzb uno@arturoburela.com"
        ]
      }
    ]
  },
  "storage": {
    "files": [
      {
        "path": "/etc/sudoers.d/aburela",
        "contents": {
          "compression": "",
          "source": "data:,aburela%20ALL%3D(ALL)%20NOPASSWD%3A%20ALL"
        },
        "mode": 288
      }
    ],
    "filesystems": [
      {
        "device": "/dev/mapper/root",
        "format": "xfs",
        "label": "root",
        "wipeFilesystem": true
      }
    ],
    "luks": [
      {
        "clevis": {
          "tpm2": true
        },
        "device": "/dev/disk/by-partlabel/root",
        "label": "luks-root",
        "name": "root",
        "wipeVolume": true
      }
    ]
  }
}
